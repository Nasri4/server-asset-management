NODE_ENV=development
PORT=5000

# SQL Server
DB_SERVER=localhost
DB_DATABASE=SERVER_ASSET_MANAGEMENT
DB_USER=app_user
DB_PASSWORD=change_me
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# Auth cookie + JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h
COOKIE_NAME=sam_session
COOKIE_SECURE=false

# Dev-only: allows creating the first Admin user via Postman.
# Leave blank to disable. Never enable in production.
DEV_BOOTSTRAP_TOKEN=

# Reverse proxy (set true when behind nginx/ingress)
TRUST_PROXY=false

# CORS
# Comma-separated list of allowed origins (e.g. https://sam.company.internal)
# In production, the backend enforces that this is set.
CORS_ORIGINS=http://localhost:3000

# Server credentials encryption (required to store/reveal server login passwords)
# Generate a key with one of:
# - Node (cross-platform): `npm run gen:credentials-key`
# - OpenSSL: `openssl rand -base64 32`
CREDENTIALS_ENCRYPTION_KEY=change_me

# Optional SMS provider (leave blank to run in placeholder mode)
SMS_API_URL=
